{
  "info": {
    "name": "Distributed Rate Limiter Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Check Rate Limit (Sliding Window)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Tier", "value": "free" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"free_user_1\",\n  \"endpoint\": \"/api/resource\",\n  \"timestamp\": 1784189000000\n}"
        },
        "url": {
          "raw": "https://rate-limiter-three.vercel.app/api/v1/check-limit"
        }
      }
    },
    {
      "name": "Check Limit with API Key (Hashed on Server)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "free_key_123" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"endpoint\": \"/api/resource\"\n}"
        },
        "url": {
          "raw": "https://rate-limiter-three.vercel.app/api/v1/check-limit"
        }
      }
    },
    {
