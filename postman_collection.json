      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "free_key_123" },
          { "key": "X-Chaos-Redis-Timeout", "value": "true" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"endpoint\": \"/api/resource\"\n}"
